<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dheeraj | Creative Developer</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <style>
        /* --- Dynamic Theme Variables --- */
        :root {
            --gold: #d4af37;
            --gold-glow: rgba(212, 175, 55, 0.5);
            --gold-light: rgba(212, 175, 55, 0.1);
            --bg: #050505;
            --text-main: #f4f4f9;
            --text-muted: #b0b0b0;
            --card-bg: rgba(20, 20, 20, 0.6);
        }

        body.neon-mode {
            --gold: #ff00ff; 
            --gold-glow: rgba(255, 0, 255, 0.8);
            --gold-light: rgba(255, 0, 255, 0.15);
            --bg: #050011; 
            --text-main: #00ffff; 
            --text-muted: #aa88ff;
            --card-bg: rgba(10, 0, 20, 0.7);
        }

        /* --- Global Reset & Hide Scrollbar --- */
        body, html {
            margin: 0; padding: 0; width: 100%;
            background: var(--bg); color: var(--text-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 1400vh; cursor: none; transition: background 0.5s ease;
            scrollbar-width: none; -ms-overflow-style: none;
        }
        body::-webkit-scrollbar { display: none; }

        /* --- Cinematic Film Grain --- */
        #noise-overlay {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            pointer-events: none; z-index: 9998; opacity: 0.05;
            background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
        }

        /* --- Preloader --- */
        #preloader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 10001; display: flex; flex-direction: column; pointer-events: none;
        }
        .preloader-half {
            width: 100%; height: 50vh; background: #000;
            transition: transform 1.2s cubic-bezier(0.77, 0, 0.175, 1);
        }
        .preloader-text {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            font-size: 2rem; font-weight: bold; letter-spacing: 5px; color: #fff; z-index: 10002;
            transition: opacity 0.5s ease;
        }
        .preloader-text span { color: var(--gold); transition: 0.5s;}
        .loaded .preloader-half.top { transform: translateY(-100%); }
        .loaded .preloader-half.bottom { transform: translateY(100%); }
        .loaded .preloader-text { opacity: 0; }

        /* --- Golden Thread --- */
        #thread-container {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: 5; pointer-events: none;
        }
        #golden-thread {
            fill: transparent; stroke: var(--gold); stroke-width: 2;
            stroke-dasharray: 3000; stroke-dashoffset: 3000; stroke-linecap: round;
            filter: drop-shadow(0 0 8px var(--gold-glow)); transition: stroke 0.5s ease;
        }

        /* --- ADVANCED FUNCTIONAL CURSOR --- */
        .cursor-dot {
            position: fixed; top: 0; left: 0; width: 6px; height: 6px; 
            background-color: var(--gold); border-radius: 50%; 
            pointer-events: none; z-index: 10000; transform: translate(-50%, -50%);
            box-shadow: 0 0 10px var(--gold); transition: background-color 0.5s, box-shadow 0.5s, transform 0.1s;
            /* X-Ray Contrast Effect */
            mix-blend-mode: difference;
        }
        .cursor-outline {
            position: fixed; top: 0; left: 0; width: 40px; height: 40px;
            border: 1px solid var(--gold-glow); border-radius: 50%;
            pointer-events: none; z-index: 9999; transform: translate(-50%, -50%);
            will-change: width, height, transform, border-radius;
            transition: border-color 0.5s, background-color 0.2s;
            display: flex; justify-content: center; align-items: center;
            overflow: hidden;
            /* X-Ray Contrast Effect */
            mix-blend-mode: difference;
        }
        /* New Contextual Text inside the cursor */
        .cursor-text {
            color: #fff; font-size: 0.75rem; font-weight: bold; letter-spacing: 1px;
            opacity: 0; transform: scale(0.5); transition: opacity 0.2s, transform 0.2s;
            white-space: nowrap; pointer-events: none;
        }

        /* --- UI Overlays --- */
        .top-header, .bottom-footer {
            position: fixed; left: 0; width: 100%; padding: 20px 50px;
            display: flex; justify-content: space-between; align-items: center;
            box-sizing: border-box; z-index: 100; background: rgba(5, 5, 5, 0.2);
            backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        }
        .top-header { top: 0; border-bottom: 1px solid var(--gold-light); }
        .bottom-footer { bottom: 0; padding: 15px 50px; border-top: 1px solid var(--gold-light); }
        .logo { font-size: 1.5rem; font-weight: bold; letter-spacing: 1px; color: var(--text-main); transition: 0.5s;}
        .logo span { color: var(--gold); transition: 0.5s;}
        nav a, .social-links a {
            color: var(--text-main); text-decoration: none; margin-left: 30px;
            font-size: 1rem; text-transform: uppercase; letter-spacing: 1px;
            transition: color 0.3s ease; cursor: none; display: inline-block;
        }
        nav a:hover, .social-links a:hover { color: var(--gold); }

        /* --- Background Canvases --- */
        #dust-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; pointer-events: none; }
        #webgl-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; }

        /* --- 3D Scene Wrapper --- */
        .scene {
            position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
            perspective: 1000px; transform-style: preserve-3d;
            overflow: hidden; pointer-events: none; z-index: 10;
        }

        .kinetic-text {
            position: absolute; top: 50%; left: 50%;
            font-size: 15rem; font-weight: 900; white-space: nowrap; color: transparent;
            -webkit-text-stroke: 2px var(--gold-light); transform-style: preserve-3d; pointer-events: none; will-change: transform; transition: 0.5s;
        }

        .depth-layer {
            position: absolute; top: 50%; left: 50%; width: 80%; max-width: 900px; text-align: center;
            transform: translate(-50%, -50%); transform-style: preserve-3d;
            pointer-events: auto; will-change: transform, opacity, filter;
        }

        /* --- Typography --- */
        h1 { 
            font-size: 5rem; margin-bottom: 10px; letter-spacing: 2px;
            background: linear-gradient(45deg, var(--gold), #fff, var(--gold)); background-size: 200% auto;
            color: transparent; -webkit-background-clip: text; background-clip: text;
            animation: shimmerGold 4s linear infinite; display: inline-block;
        }
        @keyframes shimmerGold { to { background-position: 200% center; } }
        
        h2 { font-size: 3.5rem; color: var(--gold); margin-bottom: 20px; display: inline-block; transition: 0.5s; }
        .subtitle { font-size: 1.3rem; color: var(--text-muted); line-height: 1.6; display: inline-block; transition: 0.5s; }
        .quote { font-size: 2.5rem; font-style: italic; color: var(--text-main); font-weight: 300; line-height: 1.4; border-left: 4px solid var(--gold); padding-left: 30px; text-align: left; transition: 0.5s; }

        /* --- Content Modules --- */
        .skills-container { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; margin-top: 30px; }
        .skill-tag {
            padding: 12px 24px; font-size: 1.1rem; font-weight: bold;
            background: rgba(255, 255, 255, 0.03); border: 1px solid var(--gold-light);
            border-radius: 30px; color: var(--text-main); backdrop-filter: blur(5px); cursor: none; 
            transition: background 0.3s, border-color 0.3s, color 0.3s;
            display: inline-block; will-change: transform;
        }
        .skill-tag:hover { background: var(--gold-light); border-color: var(--gold); color: var(--gold); }

        .timeline { margin-top: 50px; text-align: left; border-left: 2px solid var(--gold-light); padding-left: 30px; position: relative; transition: 0.5s;}
        .timeline-item { margin-bottom: 40px; position: relative; }
        .timeline-item::before {
            content: ''; position: absolute; left: -37px; top: 5px; width: 12px; height: 12px;
            background: var(--bg); border: 2px solid var(--gold); border-radius: 50%; transition: 0.3s;
        }
        .timeline-item:hover::before { background: var(--gold); box-shadow: 0 0 15px var(--gold-glow); }
        .timeline-date { color: var(--gold); font-weight: bold; letter-spacing: 1px; margin-bottom: 5px; display: inline-block; transition: 0.5s;}
        .timeline-title { font-size: 1.5rem; margin: 0 0 10px 0; display: inline-block; }
        .timeline-desc { color: var(--text-muted); line-height: 1.5; margin: 0; display: inline-block; transition: 0.5s;}

        .project-card {
            background: var(--card-bg); border: 1px solid var(--gold-light); cursor: none;
            border-radius: 15px; padding: 40px; margin-top: 30px; backdrop-filter: blur(10px); text-align: left;
            transform-style: preserve-3d; transition: border 0.5s, background 0.5s, box-shadow 0.5s;
        }
        .project-card:hover { border-color: var(--gold); box-shadow: 0 30px 60px var(--gold-light); }
        .project-card > * { transform: translateZ(30px); transition: 0.2s ease-out; }
        .project-card h3 { color: var(--gold); font-size: 2rem; margin: 0 0 10px 0; transition: 0.5s;}
        .project-card p { color: var(--text-muted); font-size: 1.1rem; line-height: 1.5; margin-bottom: 20px; transition: 0.5s;}
        
        .cta-btn {
            display: inline-block; padding: 15px 40px; font-size: 1.2rem; font-weight: bold; text-transform: uppercase;
            color: #000; background: var(--gold); border-radius: 5px; text-decoration: none; cursor: none; 
            will-change: transform; 
        }
        .cta-btn:hover { box-shadow: 0 0 40px var(--gold-glow); }

    </style>
</head>
