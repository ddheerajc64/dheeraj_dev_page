    <script>
        // --- PRELOADER ---
        let loadProgress = 0; const progressEl = document.getElementById('progress'); const preloader = document.getElementById('preloader');
        let isLoaded = false;
        let loaderInterval = setInterval(() => {
            loadProgress += Math.floor(Math.random() * 5) + 1;
            if (loadProgress >= 100) {
                loadProgress = 100; clearInterval(loaderInterval);
                document.body.classList.add('loaded'); isLoaded = true;
                setTimeout(() => { preloader.style.display = 'none'; }, 1500);
            }
            progressEl.innerText = loadProgress;
        }, 30);

        // --- EASTER EGG (NEON) ---
        let typedCode = ''; const secretCode = 'neon'; let isNeonMode = false; let themeColor = 0xd4af37;
        window.addEventListener('keydown', (e) => {
            typedCode += e.key.toLowerCase(); if (typedCode.length > secretCode.length) typedCode = typedCode.slice(-secretCode.length);
            if (typedCode === secretCode) {
                isNeonMode = !isNeonMode; document.body.classList.toggle('neon-mode');
                themeColor = isNeonMode ? 0xff00ff : 0xd4af37; torusMaterial.color.setHex(themeColor);
                document.body.style.background = '#fff'; setTimeout(() => { document.body.style.background = ''; }, 100);
            }
        });

        // --- THREE.JS ---
        const webglCanvas = document.getElementById('webgl-canvas');
        const scene = new THREE.Scene(); const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas: webglCanvas, alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight); renderer.setPixelRatio(window.devicePixelRatio);
        const geometry = new THREE.TorusKnotGeometry(10, 3, 100, 16);
        const torusMaterial = new THREE.MeshBasicMaterial({ color: themeColor, wireframe: true, transparent: true, opacity: 0.15 });
        const torusKnot = new THREE.Mesh(geometry, torusMaterial); scene.add(torusKnot); camera.position.z = 30;

        // --- CURSOR LOGIC & VELOCITY TRACKING ---
        const cursorWrapper = document.getElementById('cursor-wrapper');
        const outline = document.getElementById('cursor-outline');
        const dot = document.getElementById('cursor-dot');
        const cursorText = document.querySelector('.cursor-text');
        const holdRingSvg = document.querySelector('.cursor-progress-svg');
        const holdRingPath = document.getElementById('hold-ring');
        
        let mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        let lastMouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        let outlinePos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        
        let targetW = 40, targetH = 40, targetBr = 50; 
        let curW = 40, curH = 40, curBr = 50;
        let hoverType = 'none'; // 'text', 'button', 'view', 'hold', 'none'
        let hoverTarget = null;
        let mouse3D = { x: 0, y: 0 };
        
        // Hold-to-Confirm Variables
        let isHolding = false;
        let holdProgress = 0;

        window.addEventListener('mousemove', (e) => {
            mouse.x = e.clientX; mouse.y = e.clientY;
            mouse3D.x = (e.clientX / window.innerWidth) * 2 - 1;
            mouse3D.y = -(e.clientY / window.innerHeight) * 2 + 1;
        });

        window.addEventListener('mousedown', () => { 
            if(hoverType === 'hold') isHolding = true; 
            else { targetW = 15; targetH = 15; outline.style.backgroundColor = isNeonMode?'var(--gold)':'var(--gold)'; }
        });
        window.addEventListener('mouseup', () => { 
            isHolding = false; holdProgress = 0; holdRingPath.style.strokeDashoffset = 283;
            if(hoverType === 'none') { targetW = 40; targetH = 40; outline.style.backgroundColor = 'transparent'; }
        });

        // Physical Buttons
        document.querySelectorAll('.magnetic-pull').forEach(el => {
            el.addEventListener('mouseenter', () => {
                if(isHolding) return; hoverType = 'button'; hoverTarget = el;
                let rect = el.getBoundingClientRect();
                targetW = rect.width + 20; targetH = rect.height + 20; targetBr = el.classList.contains('skill-tag') ? 30 : 8; 
                outline.style.backgroundColor = 'var(--gold-light)';
            });
            el.addEventListener('mousemove', (e) => {
                const rect = el.getBoundingClientRect();
                const x = (e.clientX - (rect.left + rect.width / 2)) * 0.3; const y = (e.clientY - (rect.top + rect.height / 2)) * 0.3;
                el.style.transform = `translate(${x}px, ${y}px)`;
            });
            el.addEventListener('mouseleave', () => {
                if(!isHolding) { hoverType = 'none'; hoverTarget = null; targetW = 40; targetH = 40; targetBr = 50; outline.style.backgroundColor = 'transparent'; }
                el.style.transform = `translate(0px, 0px)`;
            });
        });

        // Text Magnetism
        document.querySelectorAll('.magnetic-text').forEach(el => {
            el.addEventListener('mouseenter', () => {
                if(isHolding) return; hoverType = 'text';
                targetW = 80; targetH = 15; targetBr = 8; outline.style.backgroundColor = 'var(--gold-light)'; outline.style.borderWidth = '0px'; 
            });
            el.addEventListener('mouseleave', () => {
                if(!isHolding) { hoverType = 'none'; targetW = 40; targetH = 40; targetBr = 50; outline.style.backgroundColor = 'transparent'; outline.style.borderWidth = '1px'; }
            });
        });

        // The Media Portal (Projects)
        document.querySelectorAll('.cursor-view').forEach(el => {
            el.addEventListener('mouseenter', () => {
                if(isHolding) return; hoverType = 'view';
                targetW = 200; targetH = 200; targetBr = 50;
                outline.style.backgroundColor = 'var(--bg)'; outline.style.borderWidth = '0px';
                outline.style.backgroundImage = `url('${el.getAttribute('data-image')}')`; // Inject Image
                cursorText.style.opacity = '1'; cursorText.style.transform = 'scale(1)'; dot.style.opacity = '0';
            });
            el.addEventListener('mouseleave', () => {
                if(!isHolding) { hoverType = 'none'; targetW = 40; targetH = 40; targetBr = 50; outline.style.backgroundColor = 'transparent'; outline.style.borderWidth = '1px'; outline.style.backgroundImage = 'none'; }
                cursorText.style.opacity = '0'; cursorText.style.transform = 'scale(0.5)'; dot.style.opacity = '1';
            });
        });

        // Hold to Confirm (CTA)
        document.querySelectorAll('.cursor-hold').forEach(el => {
            el.addEventListener('mouseenter', () => {
                hoverType = 'hold'; targetW = 80; targetH = 80; targetBr = 50;
                outline.style.backgroundColor = 'var(--gold-light)'; outline.style.borderWidth = '0px';
                cursorText.innerText = "HOLD"; cursorText.style.opacity = '1'; cursorText.style.transform = 'scale(1)';
                holdRingSvg.style.opacity = '1'; dot.style.opacity = '0';
            });
            el.addEventListener('mouseleave', () => {
                isHolding = false; holdProgress = 0; holdRingPath.style.strokeDashoffset = 283;
                hoverType = 'none'; targetW = 40; targetH = 40; targetBr = 50;
                outline.style.backgroundColor = 'transparent'; outline.style.borderWidth = '1px';
                cursorText.style.opacity = '0'; cursorText.style.transform = 'scale(0.5)'; cursorText.innerText = "VIEW ↗";
                holdRingSvg.style.opacity = '0'; dot.style.opacity = '1';
            });
        });

        // Tilt Cards
        document.querySelectorAll('.tilt-card').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect(); const x = e.clientX - rect.left; const y = e.clientY - rect.top;  
                const centerX = rect.width / 2; const centerY = rect.height / 2;
                card.style.transform = `perspective(1000px) rotateX(${((y - centerY) / centerY) * -10}deg) rotateY(${((x - centerX) / centerX) * 10}deg) scale3d(1.02, 1.02, 1.02)`;
            });
            card.addEventListener('mouseleave', () => { card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`; });
        });

        // The "Repulsive" Easter Egg Button
        const repelBtn = document.querySelector('.repel-btn');
        let repelX = 0, repelY = 0;
        
        // --- PARTICLES & SHOCKWAVES ---
        const dustCanvas = document.getElementById('dust-canvas'); const ctx = dustCanvas.getContext('2d');
        const layers = document.querySelectorAll('.depth-layer'); const kineticTexts = document.querySelectorAll('.kinetic-text');
        const threadPath = document.getElementById('golden-thread');
        let targetScroll = 0, currentScroll = 0; const MAX_SCROLL = 13000; 

        function resize() { 
            dustCanvas.width = window.innerWidth; dustCanvas.height = window.innerHeight; 
            renderer.setSize(window.innerWidth, window.innerHeight); camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix();
        }
        window.addEventListener('resize', resize); resize();
        window.addEventListener('wheel', (e) => { if(isLoaded) targetScroll += e.deltaY * 1.5; targetScroll = Math.max(0, Math.min(targetScroll, MAX_SCROLL)); }, { passive: false });

        let touchStartY = 0;
        window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: false });
        window.addEventListener('touchmove', (e) => { if(!isLoaded) return; let touchY = e.touches[0].clientY; targetScroll += (touchStartY - touchY) * 2.5; targetScroll = Math.max(0, Math.min(targetScroll, MAX_SCROLL)); touchStartY = touchY; }, { passive: false });

        let particles = [];
        class Particle3D {
            constructor() { this.x = (Math.random() - 0.5) * 4000; this.y = (Math.random() - 0.5) * 4000; this.z = Math.random() * 15000; this.baseSize = Math.random() * 3 + 1; }
            draw(scrollOffset) {
                let activeZ = this.z - (Date.now() * 0.05) - (scrollOffset * 1.5); activeZ = ((activeZ % 15000) + 15000) % 15000;
                let scale = 800 / (800 + activeZ); let px = dustCanvas.width / 2 + this.x * scale; let py = dustCanvas.height / 2 + this.y * scale;
                let opacity = Math.min(1, ((15000 - activeZ) / 15000) * 1.5); 
                let r = (themeColor >> 16) & 255; let g = (themeColor >> 8) & 255; let b = themeColor & 255;
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${opacity})`; ctx.beginPath(); ctx.arc(px, py, this.baseSize * scale, 0, Math.PI * 2); ctx.fill();
            }
        }
        for(let i = 0; i < 300; i++) particles.push(new Particle3D());

        let shockwaves = [];
        class BurstParticle {
            constructor(x, y, power = 10) {
                this.x = x; this.y = y; const angle = Math.random() * Math.PI * 2; const speed = Math.random() * power + 2;
                this.vx = Math.cos(angle) * speed; this.vy = Math.sin(angle) * speed;
                this.size = Math.random() * 4 + 1; this.life = 1.0; this.decay = Math.random() * 0.05 + 0.02;
            }
            updateAndDraw() {
                this.x += this.vx; this.y += this.vy; this.life -= this.decay;
                let r = (themeColor >> 16) & 255; let g = (themeColor >> 8) & 255; let b = themeColor & 255;
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${Math.max(0, this.life)})`;
                ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
            }
        }
        function triggerExplosion(x, y, amount, power) {
            for(let i = 0; i < amount; i++) shockwaves.push(new BurstParticle(x, y, power));
        }

        window.addEventListener('mousedown', (e) => { if(!isLoaded) return; triggerExplosion(e.clientX, e.clientY, 20, 10); });

        // --- MASTER LOOP ---
        function animate() {
            currentScroll += (targetScroll - currentScroll) * 0.08;

            // Hold-to-Confirm Math
            if(isHolding && hoverType === 'hold') {
                holdProgress += 1.5; // Fills up over ~1-2 seconds
                let offset = 283 - (283 * (holdProgress / 100));
                holdRingPath.style.strokeDashoffset = Math.max(0, offset);
                
                // Trigger action when full
                if(holdProgress >= 100) {
                    isHolding = false;
                    cursorText.innerText = "LAUNCHING";
                    triggerExplosion(mouse.x, mouse.y, 100, 30); // Massive boom
                    setTimeout(() => { alert("Redirecting to Email / Contact Form!"); }, 500);
                }
            }

            // Velocity & Stretch Math for Cursor
            let velX = mouse.x - lastMouse.x;
            let velY = mouse.y - lastMouse.y;
            let speed = Math.sqrt(velX * velX + velY * velY);
            
            // Only stretch if we are NOT hovering over an interactive element (keep it a circle for UI feedback)
            let scaleX = 1, scaleY = 1, angle = 0;
            if (hoverType === 'none' && speed > 5) {
                angle = Math.atan2(velY, velX) * 180 / Math.PI;
                scaleX = 1 + Math.min(speed * 0.015, 0.8); // Stretch forward
                scaleY = 1 - Math.min(speed * 0.005, 0.4); // Squash sides
            }

            lastMouse.x = mouse.x; lastMouse.y = mouse.y;

            if (hoverType === 'button' && hoverTarget && !isHolding) {
                let rect = hoverTarget.getBoundingClientRect();
                outlinePos.x += ((rect.left + rect.width / 2) - outlinePos.x) * 0.25;
                outlinePos.y += ((rect.top + rect.height / 2) - outlinePos.y) * 0.25;
            } else {
                outlinePos.x += (mouse.x - outlinePos.x) * 0.25;
                outlinePos.y += (mouse.y - outlinePos.y) * 0.25;
            }
            
            curW += (targetW - curW) * 0.25; curH += (targetH - curH) * 0.25; curBr += (targetBr - curBr) * 0.25;
            
            cursorWrapper.style.transform = `translate3d(${outlinePos.x}px, ${outlinePos.y}px, 0) rotate(${angle}deg) scale(${scaleX}, ${scaleY})`;
            outline.style.width = curW + 'px'; outline.style.height = curH + 'px'; outline.style.borderRadius = curBr + '%';
            
            // Inner elements negate the rotation/scale so they don't look weird
            outline.style.top = -(curH/2) + 'px'; outline.style.left = -(curW/2) + 'px';
            cursorText.style.transform = `rotate(${-angle}deg) scale(${hoverType==='view'||hoverType==='hold' ? 1 : 0.5})`;
            
            // SVG Path
            threadPath.style.strokeDashoffset = 3000 * (1 - (currentScroll / MAX_SCROLL));

            // Repel Button Math
            if(repelBtn) {
                let rect = repelBtn.getBoundingClientRect();
                let bx = rect.left + rect.width / 2; let by = rect.top + rect.height / 2;
                let dist = Math.hypot(mouse.x - bx, mouse.y - by);
                if(dist < 150) { repelX += (bx - mouse.x) * 0.2; repelY += (by - mouse.y) * 0.2; }
                repelX *= 0.8; repelY *= 0.8; // Friction
                repelBtn.style.transform = `translate(${repelX}px, ${repelY}px)`;
            }

            layers.forEach(layer => {
                let initialZ = parseFloat(layer.getAttribute('data-z')); let zPos = initialZ + (currentScroll * 2.5); let opacity = 1, blurAmount = 0;
                if (zPos > 300) { opacity = 1 - ((zPos - 300) / 400); blurAmount = (zPos - 300) / 30; } 
                else if (zPos < -1500) { opacity = 1 - (Math.abs(zPos + 1500) / 2500); blurAmount = Math.abs(zPos + 1500) / 300; }
                opacity = Math.max(0, Math.min(1, opacity)); 
                layer.style.pointerEvents = opacity < 0.1 ? 'none' : 'auto';
                layer.style.transform = `translate(-50%, -50%) translateZ(${zPos}px)`; layer.style.opacity = opacity; layer.style.filter = `blur(${blurAmount}px)`;
            });

            kineticTexts.forEach((text, index) => {
                let zPos = parseFloat(text.getAttribute('data-z')) + (currentScroll * 2.5);
                let opacity = Math.max(0, Math.min(0.3, zPos > -1000 ? 1 - ((zPos + 1000) / 1500) : 0.3)); 
                text.style.transform = `translate(calc(-50% + ${currentScroll * 0.8 * (index % 2 === 0 ? -1 : 1)}px), -50%) translateZ(${zPos}px)`;
                text.style.opacity = opacity;
            });

            torusKnot.rotation.x += 0.005; torusKnot.rotation.y += 0.005;
            torusKnot.position.x += (mouse3D.x * 5 - torusKnot.position.x) * 0.05; torusKnot.position.y += (mouse3D.y * 5 - torusKnot.position.y) * 0.05; torusKnot.position.z = (currentScroll * 0.005);
            renderer.render(scene, camera);

            ctx.clearRect(0, 0, dustCanvas.width, dustCanvas.height); particles.forEach(p => p.draw(currentScroll));
            for(let i = shockwaves.length - 1; i >= 0; i--) { shockwaves[i].updateAndDraw(); if(shockwaves[i].life <= 0) shockwaves.splice(i, 1); }

            requestAnimationFrame(animate);
        }

        animate();
    </script>
</body>
</html>
