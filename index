    <script>
        // --- PRELOADER ---
        let loadProgress = 0; const progressEl = document.getElementById('progress'); const preloader = document.getElementById('preloader');
        let isLoaded = false;
        let loaderInterval = setInterval(() => {
            loadProgress += Math.floor(Math.random() * 5) + 1;
            if (loadProgress >= 100) {
                loadProgress = 100; clearInterval(loaderInterval);
                document.body.classList.add('loaded'); isLoaded = true;
                setTimeout(() => { preloader.style.display = 'none'; }, 1500);
            }
            progressEl.innerText = loadProgress;
        }, 30);

        // --- CONTEXT MENU LOGIC ---
        const contextMenu = document.getElementById('context-menu');
        window.addEventListener('contextmenu', (e) => {
            e.preventDefault();
            contextMenu.style.display = 'block';
            // Keep menu within viewport bounds
            let x = e.clientX; let y = e.clientY;
            if(x + 200 > window.innerWidth) x -= 200;
            if(y + 200 > window.innerHeight) y -= 200;
            contextMenu.style.left = x + 'px';
            contextMenu.style.top = y + 'px';
        });
        window.addEventListener('click', () => { contextMenu.style.display = 'none'; });

        // Dummy copy function
        function copyEmail() { alert("Email copied to clipboard: contact@dheeraj.com"); }

        // --- THEME ENGINE ---
        let currentThemeColor = 0xd4af37; // Default Gold
        const themeColors = { 'theme-default': 0xd4af37, 'theme-neon': 0xff00ff, 'theme-matrix': 0x00ff41, 'theme-blood': 0xff003c };
        const themeBtns = document.querySelectorAll('.theme-btn');

        function switchTheme(themeName) {
            // Update Body Class
            document.body.className = themeName;
            if(isLoaded) document.body.classList.add('loaded'); // Preserve preloader state
            
            // Update Active Button
            themeBtns.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            // Update Three.js & Canvas Particle Hex Color
            currentThemeColor = themeColors[themeName];
            torusMaterial.color.setHex(currentThemeColor);
            
            // Flash Effect
            document.body.style.background = '#fff';
            setTimeout(() => { document.body.style.background = ''; }, 50);
        }

        // --- THREE.JS BACKGROUND ---
        const webglCanvas = document.getElementById('webgl-canvas');
        const scene = new THREE.Scene(); const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas: webglCanvas, alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight); renderer.setPixelRatio(window.devicePixelRatio);
        const geometry = new THREE.TorusKnotGeometry(10, 3, 100, 16);
        const torusMaterial = new THREE.MeshBasicMaterial({ color: currentThemeColor, wireframe: true, transparent: true, opacity: 0.15 });
        const torusKnot = new THREE.Mesh(geometry, torusMaterial); scene.add(torusKnot); camera.position.z = 30;

        // --- MULTI-TOOL CURSOR ---
        const cursorWrapper = document.getElementById('cursor-wrapper'); const outline = document.getElementById('cursor-outline');
        const dot = document.getElementById('cursor-dot'); const cursorText = document.querySelector('.cursor-text');
        const holdRingSvg = document.querySelector('.cursor-progress-svg'); const holdRingPath = document.getElementById('hold-ring');
        
        let mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 }; let lastMouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        let outlinePos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        let targetW = 40, targetH = 40, targetBr = 50; let curW = 40, curH = 40, curBr = 50;
        let hoverType = 'none'; let hoverTarget = null; let mouse3D = { x: 0, y: 0 };
        let isHolding = false; let holdProgress = 0;

        // Hero Parallax Tracking Variables
        const heroTitle = document.getElementById('hero-title');

        window.addEventListener('mousemove', (e) => {
            mouse.x = e.clientX; mouse.y = e.clientY;
            dot.style.left = mouse.x + 'px'; dot.style.top = mouse.y + 'px';
            mouse3D.x = (e.clientX / window.innerWidth) * 2 - 1; mouse3D.y = -(e.clientY / window.innerHeight) * 2 + 1;
            
            // Hero Parallax Move (Opposite to mouse)
            if(currentScroll < 1000) {
                let px = mouse3D.x * -20; let py = mouse3D.y * 20;
                heroTitle.style.transform = `translate3d(${px}px, ${py}px, 0)`;
            }
        });

        window.addEventListener('mousedown', () => { 
            if(hoverType === 'hold') isHolding = true; 
            else { targetW = 15; targetH = 15; outline.style.backgroundColor = 'var(--accent)'; }
        });
        window.addEventListener('mouseup', () => { 
            isHolding = false; holdProgress = 0; holdRingPath.style.strokeDashoffset = 283;
            if(hoverType === 'none') { targetW = 40; targetH = 40; outline.style.backgroundColor = 'transparent'; }
        });

        document.querySelectorAll('.magnetic-pull').forEach(el => {
            el.addEventListener('mouseenter', () => {
                if(isHolding) return; hoverType = 'button'; hoverTarget = el;
                let rect = el.getBoundingClientRect(); targetW = rect.width + 20; targetH = rect.height + 20; targetBr = el.classList.contains('skill-tag') ? 30 : 8; outline.style.backgroundColor = 'var(--accent-light)';
            });
            el.addEventListener('mousemove', (e) => { const rect = el.getBoundingClientRect(); const x = (e.clientX - (rect.left + rect.width / 2)) * 0.3; const y = (e.clientY - (rect.top + rect.height / 2)) * 0.3; el.style.transform = `translate(${x}px, ${y}px)`; });
            el.addEventListener('mouseleave', () => { if(!isHolding) { hoverType = 'none'; hoverTarget = null; targetW = 40; targetH = 40; targetBr = 50; outline.style.backgroundColor = 'transparent'; } el.style.transform = `translate(0px, 0px)`; });
        });

        document.querySelectorAll('.magnetic-text').forEach(el => {
            el.addEventListener('mouseenter', () => { if(isHolding) return; hoverType = 'text'; targetW = 80; targetH = 15; targetBr = 8; outline.style.backgroundColor = 'var(--accent-light)'; outline.style.borderWidth = '0px'; });
            el.addEventListener('mouseleave', () => { if(!isHolding) { hoverType = 'none'; targetW = 40; targetH = 40; targetBr = 50; outline.style.backgroundColor = 'transparent'; outline.style.borderWidth = '1px'; } });
        });

        document.querySelectorAll('.cursor-view').forEach(el => {
            el.addEventListener('mouseenter', () => { if(isHolding) return; hoverType = 'view'; targetW = 200; targetH = 200; targetBr = 50; outline.style.backgroundColor = 'var(--bg)'; outline.style.borderWidth = '0px'; outline.style.backgroundImage = `url('${el.getAttribute('data-image')}')`; cursorText.style.opacity = '1'; cursorText.style.transform = 'scale(1)'; dot.style.opacity = '0'; });
            el.addEventListener('mouseleave', () => { if(!isHolding) { hoverType = 'none'; targetW = 40; targetH = 40; targetBr = 50; outline.style.backgroundColor = 'transparent'; outline.style.borderWidth = '1px'; outline.style.backgroundImage = 'none'; } cursorText.style.opacity = '0'; cursorText.style.transform = 'scale(0.5)'; dot.style.opacity = '1'; });
        });

        document.querySelectorAll('.cursor-hold').forEach(el => {
            el.addEventListener('mouseenter', () => { hoverType = 'hold'; targetW = 80; targetH = 80; targetBr = 50; outline.style.backgroundColor = 'var(--accent-light)'; outline.style.borderWidth = '0px'; cursorText.innerText = "HOLD"; cursorText.style.opacity = '1'; cursorText.style.transform = 'scale(1)'; holdRingSvg.style.opacity = '1'; dot.style.opacity = '0'; });
            el.addEventListener('mouseleave', () => { isHolding = false; holdProgress = 0; holdRingPath.style.strokeDashoffset = 283; hoverType = 'none'; targetW = 40; targetH = 40; targetBr = 50; outline.style.backgroundColor = 'transparent'; outline.style.borderWidth = '1px'; cursorText.style.opacity = '0'; cursorText.style.transform = 'scale(0.5)'; cursorText.innerText = "VIEW"; holdRingSvg.style.opacity = '0'; dot.style.opacity = '1'; });
        });

        document.querySelectorAll('.tilt-card').forEach(card => {
            card.addEventListener('mousemove', (e) => { const rect = card.getBoundingClientRect(); const x = e.clientX - rect.left; const y = e.clientY - rect.top; const centerX = rect.width / 2; const centerY = rect.height / 2; card.style.transform = `perspective(1000px) rotateX(${((y - centerY) / centerY) * -10}deg) rotateY(${((x - centerX) / centerX) * 10}deg) scale3d(1.02, 1.02, 1.02)`; });
            card.addEventListener('mouseleave', () => { card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`; });
        });

        const repelBtn = document.querySelector('.repel-btn'); let repelX = 0, repelY = 0;
        
        // --- PARTICLES, SHOCKWAVES & SCROLLING ---
        const dustCanvas = document.getElementById('dust-canvas'); const ctx = dustCanvas.getContext('2d');
        const layers = document.querySelectorAll('.depth-layer'); const kineticTexts = document.querySelectorAll('.kinetic-text');
        const threadPath = document.getElementById('golden-thread');
        const scrollProgressCircle = document.getElementById('scroll-progress-circle');
        const scrollPercentText = document.getElementById('scroll-percent-text');
        
        let targetScroll = 0, currentScroll = 0; const MAX_SCROLL = 13000; 

        function resize() { dustCanvas.width = window.innerWidth; dustCanvas.height = window.innerHeight; renderer.setSize(window.innerWidth, window.innerHeight); camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); }
        window.addEventListener('resize', resize); resize();
        window.addEventListener('wheel', (e) => { if(isLoaded) targetScroll += e.deltaY * 1.5; targetScroll = Math.max(0, Math.min(targetScroll, MAX_SCROLL)); }, { passive: false });
        let touchStartY = 0; window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: false });
        window.addEventListener('touchmove', (e) => { if(!isLoaded) return; let touchY = e.touches[0].clientY; targetScroll += (touchStartY - touchY) * 2.5; targetScroll = Math.max(0, Math.min(targetScroll, MAX_SCROLL)); touchStartY = touchY; }, { passive: false });

        let particles = [];
        class Particle3D {
            constructor() { this.x = (Math.random() - 0.5) * 4000; this.y = (Math.random() - 0.5) * 4000; this.z = Math.random() * 15000; this.baseSize = Math.random() * 3 + 1; }
            draw(scrollOffset) {
                let activeZ = this.z - (Date.now() * 0.05) - (scrollOffset * 1.5); activeZ = ((activeZ % 15000) + 15000) % 15000;
                let scale = 800 / (800 + activeZ); let px = dustCanvas.width / 2 + this.x * scale; let py = dustCanvas.height / 2 + this.y * scale;
                let opacity = Math.min(1, ((15000 - activeZ) / 15000) * 1.5); 
                let r = (currentThemeColor >> 16) & 255; let g = (currentThemeColor >> 8) & 255; let b = currentThemeColor & 255;
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${opacity})`; ctx.beginPath(); ctx.arc(px, py, this.baseSize * scale, 0, Math.PI * 2); ctx.fill();
            }
        }
        for(let i = 0; i < 300; i++) particles.push(new Particle3D());

        let shockwaves = [];
        class BurstParticle {
            constructor(x, y, power = 10) {
                this.x = x; this.y = y; const angle = Math.random() * Math.PI * 2; const speed = Math.random() * power + 2;
                this.vx = Math.cos(angle) * speed; this.vy = Math.sin(angle) * speed; this.size = Math.random() * 4 + 1; this.life = 1.0; this.decay = Math.random() * 0.05 + 0.02;
            }
            updateAndDraw() {
                this.x += this.vx; this.y += this.vy; this.life -= this.decay;
                let r = (currentThemeColor >> 16) & 255; let g = (currentThemeColor >> 8) & 255; let b = currentThemeColor & 255;
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${Math.max(0, this.life)})`; ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
            }
        }
        function triggerExplosion(x, y, amount, power) { for(let i = 0; i < amount; i++) shockwaves.push(new BurstParticle(x, y, power)); }
        window.addEventListener('mousedown', (e) => { if(!isLoaded) return; triggerExplosion(e.clientX, e.clientY, 20, 10); });

        // --- MASTER LOOP ---
        function animate() {
            currentScroll += (targetScroll - currentScroll) * 0.08;

            if(isHolding && hoverType === 'hold') {
                holdProgress += 1.5; let offset = 283 - (283 * (holdProgress / 100)); holdRingPath.style.strokeDashoffset = Math.max(0, offset);
                if(holdProgress >= 100) { isHolding = false; cursorText.innerText = "LAUNCHING"; triggerExplosion(mouse.x, mouse.y, 100, 30); setTimeout(() => { alert("Redirecting to Email Form!"); }, 500); }
            }

            let velX = mouse.x - lastMouse.x; let velY = mouse.y - lastMouse.y; let speed = Math.sqrt(velX * velX + velY * velY);
            let scaleX = 1, scaleY = 1, angle = 0;
            if (hoverType === 'none' && speed > 5) { angle = Math.atan2(velY, velX) * 180 / Math.PI; scaleX = 1 + Math.min(speed * 0.015, 0.8); scaleY = 1 - Math.min(speed * 0.005, 0.4); }
            lastMouse.x = mouse.x; lastMouse.y = mouse.y;

            if (hoverType === 'button' && hoverTarget && !isHolding) {
                let rect = hoverTarget.getBoundingClientRect(); outlinePos.x += ((rect.left + rect.width / 2) - outlinePos.x) * 0.25; outlinePos.y += ((rect.top + rect.height / 2) - outlinePos.y) * 0.25;
            } else { outlinePos.x += (mouse.x - outlinePos.x) * 0.25; outlinePos.y += (mouse.y - outlinePos.y) * 0.25; }
            
            curW += (targetW - curW) * 0.25; curH += (targetH - curH) * 0.25; curBr += (targetBr - curBr) * 0.25;
            cursorWrapper.style.transform = `translate3d(${outlinePos.x}px, ${outlinePos.y}px, 0) rotate(${angle}deg) scale(${scaleX}, ${scaleY})`;
            outline.style.width = curW + 'px'; outline.style.height = curH + 'px'; outline.style.borderRadius = curBr + '%';
            outline.style.top = -(curH/2) + 'px'; outline.style.left = -(curW/2) + 'px';
            cursorText.style.transform = `rotate(${-angle}deg) scale(${hoverType==='view'||hoverType==='hold' ? 1 : 0.5})`;
            
            // Scroll HUD & Thread Math
            let scrollPercentage = currentScroll / MAX_SCROLL;
            threadPath.style.strokeDashoffset = 3000 * (1 - scrollPercentage);
            scrollProgressCircle.style.strokeDashoffset = 125 * (1 - scrollPercentage);
            scrollPercentText.innerText = Math.round(scrollPercentage * 100);

            if(repelBtn) {
                let rect = repelBtn.getBoundingClientRect(); let bx = rect.left + rect.width / 2; let by = rect.top + rect.height / 2;
                let dist = Math.hypot(mouse.x - bx, mouse.y - by);
                if(dist < 150) { repelX += (bx - mouse.x) * 0.2; repelY += (by - mouse.y) * 0.2; }
                repelX *= 0.8; repelY *= 0.8; repelBtn.style.transform = `translate(${repelX}px, ${repelY}px)`;
            }

            layers.forEach(layer => {
                let initialZ = parseFloat(layer.getAttribute('data-z')); let zPos = initialZ + (currentScroll * 2.5); let opacity = 1, blurAmount = 0;
                if (zPos > 300) { opacity = 1 - ((zPos - 300) / 400); blurAmount = (zPos - 300) / 30; } 
                else if (zPos < -1500) { opacity = 1 - (Math.abs(zPos + 1500) / 2500); blurAmount = Math.abs(zPos + 1500) / 300; }
                opacity = Math.max(0, Math.min(1, opacity)); 
                layer.style.pointerEvents = opacity < 0.1 ? 'none' : 'auto'; layer.style.transform = `translate(-50%, -50%) translateZ(${zPos}px)`; layer.style.opacity = opacity; layer.style.filter = `blur(${blurAmount}px)`;
            });

            kineticTexts.forEach((text, index) => {
                let zPos = parseFloat(text.getAttribute('data-z')) + (currentScroll * 2.5);
                let opacity = Math.max(0, Math.min(0.3, zPos > -1000 ? 1 - ((zPos + 1000) / 1500) : 0.3)); 
                text.style.transform = `translate(calc(-50% + ${currentScroll * 0.8 * (index % 2 === 0 ? -1 : 1)}px), -50%) translateZ(${zPos}px)`; text.style.opacity = opacity;
            });

            torusKnot.rotation.x += 0.005; torusKnot.rotation.y += 0.005;
            torusKnot.position.x += (mouse3D.x * 5 - torusKnot.position.x) * 0.05; torusKnot.position.y += (mouse3D.y * 5 - torusKnot.position.y) * 0.05; torusKnot.position.z = (currentScroll * 0.005);
            renderer.render(scene, camera);

            ctx.clearRect(0, 0, dustCanvas.width, dustCanvas.height); particles.forEach(p => p.draw(currentScroll));
            for(let i = shockwaves.length - 1; i >= 0; i--) { shockwaves[i].updateAndDraw(); if(shockwaves[i].life <= 0) shockwaves.splice(i, 1); }

            requestAnimationFrame(animate);
        }
        animate();
    </script>
</body>
</html>
