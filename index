    <script>
        // --- 1. PRELOADER LOGIC ---
        let loadProgress = 0;
        const progressEl = document.getElementById('progress');
        const preloader = document.getElementById('preloader');
        let isLoaded = false;
        
        let loaderInterval = setInterval(() => {
            loadProgress += Math.floor(Math.random() * 5) + 1;
            if (loadProgress >= 100) {
                loadProgress = 100;
                clearInterval(loaderInterval);
                document.body.classList.add('loaded');
                isLoaded = true;
                setTimeout(() => { preloader.style.display = 'none'; }, 1500);
            }
            progressEl.innerText = loadProgress;
        }, 30);

        // --- 2. EASTER EGG LOGIC ---
        let typedCode = ''; const secretCode = 'neon';
        let isNeonMode = false; let themeColor = 0xd4af37;

        window.addEventListener('keydown', (e) => {
            typedCode += e.key.toLowerCase();
            if (typedCode.length > secretCode.length) typedCode = typedCode.slice(-secretCode.length);
            if (typedCode === secretCode) {
                isNeonMode = !isNeonMode;
                document.body.classList.toggle('neon-mode');
                themeColor = isNeonMode ? 0xff00ff : 0xd4af37;
                torusMaterial.color.setHex(themeColor);
                document.body.style.background = '#fff';
                setTimeout(() => { document.body.style.background = ''; }, 100);
            }
        });

        // --- 3. THREE.JS BACKGROUND ---
        const webglCanvas = document.getElementById('webgl-canvas');
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas: webglCanvas, alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);

        const geometry = new THREE.TorusKnotGeometry(10, 3, 100, 16);
        const torusMaterial = new THREE.MeshBasicMaterial({ color: themeColor, wireframe: true, transparent: true, opacity: 0.15 });
        const torusKnot = new THREE.Mesh(geometry, torusMaterial);
        scene.add(torusKnot);
        camera.position.z = 30;

        // --- 4. ADVANCED CONTEXTUAL CURSOR LOGIC ---
        const dot = document.querySelector('.cursor-dot');
        const outline = document.querySelector('.cursor-outline');
        const cursorText = document.querySelector('.cursor-text');
        
        const magneticPulls = document.querySelectorAll('.magnetic-pull');
        const magneticTexts = document.querySelectorAll('.magnetic-text');
        const viewCards = document.querySelectorAll('.cursor-view');
        
        let mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        let outlinePos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        let outlineTarget = { w: 40, h: 40, br: 50 }; 
        let currentOutline = { w: 40, h: 40, br: 50 };
        
        let hoverType = 'none'; // 'button', 'text', 'view', 'down', 'none'
        let hoverTarget = null;
        let mouse3D = { x: 0, y: 0 };
        let isMouseDown = false;

        window.addEventListener('mousemove', (e) => {
            mouse.x = e.clientX; mouse.y = e.clientY;
            dot.style.left = mouse.x + 'px'; dot.style.top = mouse.y + 'px';
            mouse3D.x = (e.clientX / window.innerWidth) * 2 - 1;
            mouse3D.y = -(e.clientY / window.innerHeight) * 2 + 1;
        });

        // Tactile Squeeze on Click
        window.addEventListener('mousedown', () => {
            isMouseDown = true;
            outlineTarget.w = 15; outlineTarget.h = 15; outlineTarget.br = 50;
            outline.style.backgroundColor = isNeonMode ? 'var(--gold)' : 'var(--gold)';
        });
        window.addEventListener('mouseup', () => {
            isMouseDown = false;
            // Reset to previous state based on hoverType
            if(hoverType === 'none') {
                outlineTarget.w = 40; outlineTarget.h = 40;
                outline.style.backgroundColor = 'transparent';
            }
        });

        // 1. Physical Button Pull
        magneticPulls.forEach(el => {
            el.addEventListener('mouseenter', () => {
                if(isMouseDown) return;
                hoverType = 'button'; hoverTarget = el;
                let rect = el.getBoundingClientRect();
                outlineTarget.w = rect.width + 20; 
                outlineTarget.h = rect.height + 20;
                outlineTarget.br = el.classList.contains('skill-tag') ? 30 : 8; 
                outline.style.backgroundColor = 'var(--gold-light)';
            });
            el.addEventListener('mousemove', (e) => {
                const rect = el.getBoundingClientRect();
                const x = (e.clientX - (rect.left + rect.width / 2)) * 0.3; 
                const y = (e.clientY - (rect.top + rect.height / 2)) * 0.3;
                el.style.transform = `translate(${x}px, ${y}px)`;
            });
            el.addEventListener('mouseleave', () => {
                if(!isMouseDown) {
                    hoverType = 'none'; hoverTarget = null;
                    outlineTarget.w = 40; outlineTarget.h = 40; outlineTarget.br = 50;
                    outline.style.backgroundColor = 'transparent';
                }
                el.style.transform = `translate(0px, 0px)`;
            });
        });

        // 2. Sensitive Text Reading Magnetism
        magneticTexts.forEach(el => {
            el.addEventListener('mouseenter', () => {
                if(isMouseDown) return;
                hoverType = 'text';
                outlineTarget.w = 80; outlineTarget.h = 15; outlineTarget.br = 8;
                outline.style.backgroundColor = 'var(--gold-light)';
                outline.style.borderWidth = '0px'; 
            });
            el.addEventListener('mouseleave', () => {
                if(!isMouseDown) {
                    hoverType = 'none';
                    outlineTarget.w = 40; outlineTarget.h = 40; outlineTarget.br = 50;
                    outline.style.backgroundColor = 'transparent';
                    outline.style.borderWidth = '1px';
                }
            });
        });

        // 3. Contextual "VIEW" State for Project Cards
        viewCards.forEach(el => {
            el.addEventListener('mouseenter', () => {
                if(isMouseDown) return;
                hoverType = 'view';
                outlineTarget.w = 90; outlineTarget.h = 90; outlineTarget.br = 50;
                outline.style.backgroundColor = 'var(--gold)'; // Solid fill
                outline.style.borderWidth = '0px';
                cursorText.style.opacity = '1';
                cursorText.style.transform = 'scale(1)';
                dot.style.opacity = '0'; // Hide the inner dot
            });
            el.addEventListener('mouseleave', () => {
                if(!isMouseDown) {
                    hoverType = 'none';
                    outlineTarget.w = 40; outlineTarget.h = 40; outlineTarget.br = 50;
                    outline.style.backgroundColor = 'transparent';
                    outline.style.borderWidth = '1px';
                }
                cursorText.style.opacity = '0';
                cursorText.style.transform = 'scale(0.5)';
                dot.style.opacity = '1';
            });
        });

        // Tilt Cards
        document.querySelectorAll('.tilt-card').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left; const y = e.clientY - rect.top;  
                const centerX = rect.width / 2; const centerY = rect.height / 2;
                const rotateX = ((y - centerY) / centerY) * -10; 
                const rotateY = ((x - centerX) / centerX) * 10;
                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
            });
            card.addEventListener('mouseleave', () => { card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`; });
        });

        // --- 5. CANVAS PARTICLES & CLICK SHOCKWAVES ---
        const dustCanvas = document.getElementById('dust-canvas');
        const ctx = dustCanvas.getContext('2d');
        const layers = document.querySelectorAll('.depth-layer');
        const kineticTexts = document.querySelectorAll('.kinetic-text');
        const threadPath = document.getElementById('golden-thread');
        
        let targetScroll = 0, currentScroll = 0;
        const MAX_SCROLL = 13000; 

        function resize() { 
            dustCanvas.width = window.innerWidth; dustCanvas.height = window.innerHeight; 
            renderer.setSize(window.innerWidth, window.innerHeight);
            camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix();
        }
        window.addEventListener('resize', resize); resize();
        
        window.addEventListener('wheel', (e) => { 
            if(isLoaded) targetScroll += e.deltaY * 1.5; 
            targetScroll = Math.max(0, Math.min(targetScroll, MAX_SCROLL));
        }, { passive: false });

        let touchStartY = 0;
        window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: false });
        window.addEventListener('touchmove', (e) => {
            if(!isLoaded) return;
            let touchY = e.touches[0].clientY; targetScroll += (touchStartY - touchY) * 2.5; 
            targetScroll = Math.max(0, Math.min(targetScroll, MAX_SCROLL)); touchStartY = touchY;
        }, { passive: false });

        let particles = [];
        class Particle3D {
            constructor() {
                this.x = (Math.random() - 0.5) * 4000; this.y = (Math.random() - 0.5) * 4000;
                this.z = Math.random() * 15000; this.baseSize = Math.random() * 3 + 1;
            }
            draw(scrollOffset) {
                let timeDrift = Date.now() * 0.05;
                let activeZ = this.z - timeDrift - (scrollOffset * 1.5);
                activeZ = ((activeZ % 15000) + 15000) % 15000;

                let scale = 800 / (800 + activeZ);
                let px = dustCanvas.width / 2 + this.x * scale; let py = dustCanvas.height / 2 + this.y * scale;
                let opacity = Math.min(1, ((15000 - activeZ) / 15000) * 1.5); 

                let r = (themeColor >> 16) & 255; let g = (themeColor >> 8) & 255; let b = themeColor & 255;
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${opacity})`;
                ctx.beginPath(); ctx.arc(px, py, this.baseSize * scale, 0, Math.PI * 2); ctx.fill();
            }
        }
        for(let i = 0; i < 300; i++) particles.push(new Particle3D());

        let shockwaves = [];
        class BurstParticle {
            constructor(x, y) {
                this.x = x; this.y = y;
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 10 + 2;
                this.vx = Math.cos(angle) * speed;
                this.vy = Math.sin(angle) * speed;
                this.size = Math.random() * 4 + 1;
                this.life = 1.0; 
                this.decay = Math.random() * 0.05 + 0.02;
            }
            updateAndDraw() {
                this.x += this.vx; this.y += this.vy;
                this.life -= this.decay;
                
                let r = (themeColor >> 16) & 255; let g = (themeColor >> 8) & 255; let b = themeColor & 255;
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${Math.max(0, this.life)})`;
                ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
            }
        }

        window.addEventListener('mousedown', (e) => {
            if(!isLoaded) return;
            for(let i = 0; i < 20; i++) shockwaves.push(new BurstParticle(e.clientX, e.clientY));
        });

        // --- Master Animation Loop ---
        function animate() {
            currentScroll += (targetScroll - currentScroll) * 0.08;

            // Highly Sensitive Cursor Physics Math
            if (hoverType === 'button' && hoverTarget && !isMouseDown) {
                let rect = hoverTarget.getBoundingClientRect();
                outlinePos.x += ((rect.left + rect.width / 2) - outlinePos.x) * 0.25;
                outlinePos.y += ((rect.top + rect.height / 2) - outlinePos.y) * 0.25;
            } else {
                outlinePos.x += (mouse.x - outlinePos.x) * 0.25;
                outlinePos.y += (mouse.y - outlinePos.y) * 0.25;
            }
            
            currentOutline.w += (outlineTarget.w - currentOutline.w) * 0.25;
            currentOutline.h += (outlineTarget.h - currentOutline.h) * 0.25;
            currentOutline.br += (outlineTarget.br - currentOutline.br) * 0.25;

            outline.style.left = outlinePos.x + 'px'; outline.style.top = outlinePos.y + 'px';
            outline.style.width = currentOutline.w + 'px'; outline.style.height = currentOutline.h + 'px';
            outline.style.borderRadius = currentOutline.br + '%';

            let scrollPercentage = currentScroll / MAX_SCROLL;
            threadPath.style.strokeDashoffset = 3000 * (1 - scrollPercentage);

            layers.forEach(layer => {
                let initialZ = parseFloat(layer.getAttribute('data-z'));
                let zPos = initialZ + (currentScroll * 2.5); 
                let opacity = 1, blurAmount = 0;

                if (zPos > 300) { opacity = 1 - ((zPos - 300) / 400); blurAmount = (zPos - 300) / 30; } 
                else if (zPos < -1500) { opacity = 1 - (Math.abs(zPos + 1500) / 2500); blurAmount = Math.abs(zPos + 1500) / 300; }
                opacity = Math.max(0, Math.min(1, opacity)); 

                layer.style.pointerEvents = opacity < 0.1 ? 'none' : 'auto';
                layer.style.transform = `translate(-50%, -50%) translateZ(${zPos}px)`;
                layer.style.opacity = opacity;
                layer.style.filter = `blur(${blurAmount}px)`;
            });

            kineticTexts.forEach((text, index) => {
                let initialZ = parseFloat(text.getAttribute('data-z'));
                let zPos = initialZ + (currentScroll * 2.5);
                let moveDirection = index % 2 === 0 ? -1 : 1;
                let opacity = zPos > -1000 ? 1 - ((zPos + 1000) / 1500) : 0.3;
                opacity = Math.max(0, Math.min(0.3, opacity)); 
                text.style.transform = `translate(calc(-50% + ${currentScroll * 0.8 * moveDirection}px), -50%) translateZ(${zPos}px)`;
                text.style.opacity = opacity;
            });

            torusKnot.rotation.x += 0.005; torusKnot.rotation.y += 0.005;
            torusKnot.position.x += (mouse3D.x * 5 - torusKnot.position.x) * 0.05;
            torusKnot.position.y += (mouse3D.y * 5 - torusKnot.position.y) * 0.05;
            torusKnot.position.z = (currentScroll * 0.005);
            renderer.render(scene, camera);

            ctx.clearRect(0, 0, dustCanvas.width, dustCanvas.height);
            particles.forEach(p => p.draw(currentScroll));
            
            for(let i = shockwaves.length - 1; i >= 0; i--) {
                shockwaves[i].updateAndDraw();
                if(shockwaves[i].life <= 0) shockwaves.splice(i, 1);
            }

            requestAnimationFrame(animate);
        }

        animate();
    </script>
</body>
</html>
