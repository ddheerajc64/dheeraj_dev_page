    <style>
        /* --- 1. DYNAMIC THEME ENGINE --- */
        :root {
            --accent: #d4af37; --accent-glow: rgba(212, 175, 55, 0.5); --accent-light: rgba(212, 175, 55, 0.1);
            --bg: #050505; --text-main: #f4f4f9; --text-muted: #b0b0b0; --card-bg: rgba(20, 20, 20, 0.6);
        }
        body.theme-neon {
            --accent: #ff00ff; --accent-glow: rgba(255, 0, 255, 0.8); --accent-light: rgba(255, 0, 255, 0.15);
            --bg: #050011; --text-main: #00ffff; --text-muted: #aa88ff; --card-bg: rgba(10, 0, 20, 0.7);
        }
        body.theme-matrix {
            --accent: #00ff41; --accent-glow: rgba(0, 255, 65, 0.6); --accent-light: rgba(0, 255, 65, 0.1);
            --bg: #000a02; --text-main: #e0ffe0; --text-muted: #008f11; --card-bg: rgba(0, 15, 5, 0.8);
        }
        body.theme-blood {
            --accent: #ff003c; --accent-glow: rgba(255, 0, 60, 0.6); --accent-light: rgba(255, 0, 60, 0.15);
            --bg: #0a0000; --text-main: #ffe0e0; --text-muted: #aa4444; --card-bg: rgba(20, 0, 0, 0.7);
        }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 1400vh;
            background: var(--bg); color: var(--text-main); font-family: 'Segoe UI', sans-serif;
            cursor: none; transition: background 0.5s ease, color 0.5s ease;
            scrollbar-width: none; -ms-overflow-style: none; overflow-x: hidden;
        }
        body::-webkit-scrollbar { display: none; }

        #noise-overlay {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; pointer-events: none; z-index: 9998; opacity: 0.05;
            background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
        }

        /* --- 2. CUSTOM CONTEXT MENU --- */
        #context-menu {
            position: fixed; display: none; z-index: 20000; width: 200px;
            background: rgba(10, 10, 10, 0.8); backdrop-filter: blur(15px);
            border: 1px solid var(--accent-light); border-radius: 8px; overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        }
        .context-item {
            padding: 12px 20px; font-size: 0.9rem; color: var(--text-main); cursor: none;
            border-bottom: 1px solid rgba(255,255,255,0.05); transition: 0.2s;
        }
        .context-item:hover { background: var(--accent-light); color: var(--accent); padding-left: 25px; }

        /* --- 3. THEME SWITCHER HUD --- */
        .theme-panel {
            position: fixed; left: 20px; top: 50%; transform: translateY(-50%); z-index: 15000;
            display: flex; flex-direction: column; gap: 15px;
        }
        .theme-btn {
            width: 15px; height: 15px; border-radius: 50%; cursor: none; border: 2px solid transparent;
            transition: 0.3s;
        }
        .theme-btn:hover { transform: scale(1.5); }
        .theme-btn.active { border-color: #fff; box-shadow: 0 0 10px #fff; }

        /* --- 4. SCROLL PROGRESS HUD --- */
        .scroll-hud {
            position: fixed; bottom: 30px; right: 30px; z-index: 15000;
            width: 50px; height: 50px; display: flex; justify-content: center; align-items: center;
        }
        .scroll-svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; transform: rotate(-90deg); }
        .scroll-circle-bg { fill: none; stroke: rgba(255,255,255,0.1); stroke-width: 3; }
        .scroll-circle { fill: none; stroke: var(--accent); stroke-width: 3; stroke-dasharray: 125; stroke-dashoffset: 125; transition: stroke-dashoffset 0.1s linear, stroke 0.5s; }
        .scroll-percent { font-size: 0.7rem; font-weight: bold; color: var(--text-main); }

        /* --- Preloader --- */
        #preloader { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 10001; display: flex; flex-direction: column; pointer-events: none; }
        .preloader-half { width: 100%; height: 50vh; background: #000; transition: transform 1.2s cubic-bezier(0.77, 0, 0.175, 1); }
        .preloader-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 2rem; font-weight: bold; letter-spacing: 5px; color: #fff; z-index: 10002; transition: 0.5s ease; }
        .preloader-text span { color: var(--accent); transition: color 0.5s;}
        .loaded .preloader-half.top { transform: translateY(-100%); }
        .loaded .preloader-half.bottom { transform: translateY(100%); }
        .loaded .preloader-text { opacity: 0; }

        /* --- Golden Thread --- */
        #thread-container { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 5; pointer-events: none; }
        #golden-thread { fill: transparent; stroke: var(--accent); stroke-width: 2; stroke-dasharray: 3000; stroke-dashoffset: 3000; stroke-linecap: round; filter: drop-shadow(0 0 8px var(--accent-glow)); transition: stroke 0.5s ease; }

        /* --- MULTI-TOOL CURSOR --- */
        .cursor-wrapper { position: fixed; top: 0; left: 0; pointer-events: none; z-index: 25000; transform-origin: center center; will-change: transform; }
        .cursor-dot { position: absolute; top: -3px; left: -3px; width: 6px; height: 6px; background-color: var(--accent); border-radius: 50%; box-shadow: 0 0 10px var(--accent); mix-blend-mode: difference; transition: 0.5s; }
        .cursor-outline { position: absolute; top: -20px; left: -20px; width: 40px; height: 40px; border: 1px solid var(--accent-glow); border-radius: 50%; display: flex; justify-content: center; align-items: center; overflow: hidden; background-size: cover; background-position: center; transition: width 0.2s, height 0.2s, border-color 0.5s, background-color 0.2s, top 0.2s, left 0.2s; mix-blend-mode: difference; }
        .cursor-text { color: #fff; font-size: 0.8rem; font-weight: bold; letter-spacing: 2px; opacity: 0; transform: scale(0.5); transition: 0.2s; white-space: nowrap; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
        .cursor-progress-svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; transform: rotate(-90deg); opacity: 0; transition: opacity 0.2s; }
        #hold-ring { stroke: var(--accent); stroke-dasharray: 283; stroke-dashoffset: 283; transition: stroke-dashoffset 0.1s linear, stroke 0.5s; }

        /* --- UI Elements --- */
        .top-header, .bottom-footer { position: fixed; left: 0; width: 100%; padding: 20px 50px; display: flex; justify-content: space-between; align-items: center; box-sizing: border-box; z-index: 100; background: rgba(5, 5, 5, 0.2); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        .top-header { top: 0; border-bottom: 1px solid var(--accent-light); }
        .bottom-footer { bottom: 0; padding: 15px 50px; border-top: 1px solid var(--accent-light); }
        .logo { font-size: 1.5rem; font-weight: bold; letter-spacing: 1px; color: var(--text-main); }
        .logo span { color: var(--accent); transition: color 0.5s;}
        nav a, .social-links a { color: var(--text-main); text-decoration: none; margin-left: 30px; text-transform: uppercase; letter-spacing: 1px; cursor: none; display: inline-block; transition: 0.3s;}
        nav a:hover, .social-links a:hover { color: var(--accent); }

        #dust-canvas, #webgl-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; }
        #dust-canvas { z-index: 2; }

        /* --- Scene & Typography --- */
        .scene { position: fixed; top: 0; left: 0; width: 100%; height: 100vh; perspective: 1000px; transform-style: preserve-3d; overflow: hidden; pointer-events: none; z-index: 10; }
        .kinetic-text { position: absolute; top: 50%; left: 50%; font-size: 15rem; font-weight: 900; white-space: nowrap; color: transparent; -webkit-text-stroke: 2px var(--accent-light); transform-style: preserve-3d; pointer-events: none; transition: 0.5s; }
        .depth-layer { position: absolute; top: 50%; left: 50%; width: 80%; max-width: 900px; text-align: center; transform: translate(-50%, -50%); transform-style: preserve-3d; pointer-events: auto; }

        /* 5. Cyber-Glitch Hover Effect */
        .glitch-text { position: relative; display: inline-block; transition: color 0.5s; }
        .glitch-text:hover { animation: glitchSkew 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite; color: transparent; }
        .glitch-text:hover::before, .glitch-text:hover::after { content: attr(data-text); position: absolute; top: 0; left: 0; width: 100%; height: 100%; color: var(--accent); }
        .glitch-text:hover::before { left: 2px; text-shadow: -2px 0 #ff00c1; clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%); animation: glitchAnim 2s infinite linear alternate-reverse; }
        .glitch-text:hover::after { left: -2px; text-shadow: -2px 0 #00fff9; clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%); animation: glitchAnim 1.5s infinite linear alternate-reverse; }
        
        @keyframes glitchAnim { 
            0% { clip-path: polygon(0 2%, 100% 2%, 100% 5%, 0 5%); } 20% { clip-path: polygon(0 15%, 100% 15%, 100% 15%, 0 15%); } 
            40% { clip-path: polygon(0 10%, 100% 10%, 100% 20%, 0 20%); } 60% { clip-path: polygon(0 1%, 100% 1%, 100% 2%, 0 2%); } 
            80% { clip-path: polygon(0 33%, 100% 33%, 100% 33%, 0 33%); } 100% { clip-path: polygon(0 44%, 100% 44%, 100% 44%, 0 44%); } 
        }
        @keyframes glitchSkew { 0% { transform: skew(0deg); } 20% { transform: skew(-20deg); } 40% { transform: skew(20deg); } 60% { transform: skew(-10deg); } 80% { transform: skew(10deg); } 100% { transform: skew(0deg); } }

        /* 6. Parallax Hero Text */
        .parallax-hero { display: inline-block; will-change: transform; transition: transform 0.1s ease-out; }

