        .project-card { background: var(--card-bg); border: 1px solid var(--accent-light); cursor: none; border-radius: 15px; padding: 40px; text-align: left; transform-style: preserve-3d; transition: border 0.5s, box-shadow 0.5s, background 0.5s; }
        .project-card:hover { border-color: var(--accent); box-shadow: 0 30px 60px var(--accent-light); }
        .project-card > * { transform: translateZ(30px); transition: 0.2s ease-out; pointer-events: none; }
        .project-card h3 { color: var(--accent); font-size: 1.8rem; margin: 0 0 10px 0; transition: 0.5s; }
        .project-card p { color: var(--text-muted); font-size: 1rem; line-height: 1.5; margin-bottom: 0; transition: 0.5s;}
        
        .repel-container { position: relative; display: inline-block; padding: 50px; margin-top: 20px;}
        .repel-btn { display: inline-block; padding: 10px 20px; font-size: 0.9rem; font-weight: bold; color: #ff3333; border: 1px solid #ff3333; background: transparent; border-radius: 5px; cursor: none; will-change: transform; }

