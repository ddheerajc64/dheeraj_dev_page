        .skills-container { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; margin-top: 30px; }
        .skill-tag { padding: 12px 24px; font-size: 1.1rem; font-weight: bold; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--accent-light); border-radius: 30px; color: var(--text-main); cursor: none; transition: background 0.3s, border-color 0.3s, color 0.3s; display: inline-block; }
